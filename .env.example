# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Deepgram ─────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── Tavily ───────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ─── Redis (auth blacklist + meeting data) ────────────────
REDIS_AUTH_URL=redis://default:<password>@<host>:<port>

# ─── Redis (vector store + transcription status) ──────────
REDIS_VECTOR_URL=redis://default:<password>@<host>:<port>

# ─── Redis (LangGraph checkpointer) ───────────────────────
REDIS_CHECKPOINTER_URL=redis://default:<password>@<host>:<port>

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your_strong_random_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ─── Webhook ──────────────────────────────────────────────
# Your deployed domain or ngrok URL (no trailing slash)
WEBHOOK_BASE_URL=https://your-domain.com
